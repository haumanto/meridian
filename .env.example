# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
# Optional: KEYED/paid endpoints (comma-separated, no spaces). Reliable tier:
# used for ALL transaction sends + as the read fallback. Each provider's API
# key is embedded in its URL. Takes precedence over user-config.json:rpcUrls.
# Leave unset to use RPC_URL only.
# RPC_URLS=https://pump.helius-rpc.com,https://NAME.solana-mainnet.quiknode.pro/TOKEN/,https://solana-mainnet.core.chainstack.com/KEY,https://lb.drpc.org/ogrpc?network=solana&dkey=KEY
#
# Optional: PUBLIC/keyless endpoints — tried FIRST for idempotent reads to
# save paid-RPC credits; keyed tier above is the automatic fallback. Sends
# never use these. Not secret — prefer user-config.json:rpcUrlsPublic; this
# env var (if set) takes precedence over it.
# RPC_URLS_PUBLIC=https://solana.drpc.org,https://api.mainnet-beta.solana.com

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here
LPAGENT_API_KEY=your_lpagent_api_key_here

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
